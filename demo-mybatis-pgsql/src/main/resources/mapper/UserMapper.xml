<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    com.example.demo.mapper.UserMapper 인터페이스의 SQL 구현체.
    namespace가 인터페이스의 FQCN과 같아야, 인터페이스 메서드 이름 = 아래 각 태그의 id 로 자동 연결된다.
    <resultMap> 없이 resultType(VO: com.example.demo.domain.User)만 사용하며, 실제 컬럼 <-> 필드 매핑은
    application.yml의 mybatis.configuration.map-underscore-to-camel-case: true 설정이 처리한다
    (예: created_at 컬럼 -> createdAt 필드).
-->
<mapper namespace="com.example.demo.mapper.UserMapper">

    <!--
        전체 목록 조회 (findAll). 조인/서브쿼리가 없는 단일 테이블 조회라 SELECT *를 그대로 사용.
        id 오름차순으로 정렬해 페이지네이션 없이도 매 호출마다 순서가 안정적으로 유지되게 한다.
    -->
    <select id="findAll" resultType="com.example.demo.domain.User">
        SELECT *
        FROM users
        ORDER BY id
    </select>

    <!--
        단건 조회 (findById). SELECT *가 아니라 컬럼을 명시적으로 나열한다 - 조회 대상 컬럼을 SQL만 보고도
        바로 파악할 수 있게 하기 위함(테이블에 컬럼이 추가돼도 이 쿼리의 응답 필드가 암묵적으로 늘어나지 않음).
        #{id}는 MyBatis 파라미터 바인딩 문법으로, PreparedStatement의 '?'로 치환되어 SQL 인젝션을 막아준다.
    -->
    <select id="findById" parameterType="long" resultType="com.example.demo.domain.User">
        SELECT id, name, email, created_at
        FROM users
        WHERE id = #{id}
    </select>

    <!--
        신규 저장 (insert). useGeneratedKeys="true" + keyProperty="id" 조합으로, INSERT 실행 후
        DB가 BIGSERIAL로 채번한 값을 파라미터로 넘긴 User 객체의 id 필드에 다시 채워 넣어준다
        (그래서 UserMapper.insert(user) 호출 뒤 user.getId()로 생성된 PK를 바로 꺼낼 수 있다).
        created_at은 컬럼 기본값(now())에 맡기고 여기서 값을 넣지 않는다.
    -->
    <insert id="insert" parameterType="com.example.demo.domain.User"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (name, email)
        VALUES (#{name}, #{email})
    </insert>

    <!-- 수정 (update). id를 조건으로 name/email만 갱신하며, email의 UNIQUE 제약을 위반하면 DB 예외가 발생한다. -->
    <update id="update" parameterType="com.example.demo.domain.User">
        UPDATE users
        SET name = #{name},
            email = #{email}
        WHERE id = #{id}
    </update>

    <!-- 삭제 (deleteById). 대상이 없어도 예외 없이 영향받은 행 수 0을 반환한다(존재 여부 확인은 서비스 계층 책임). -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM users
        WHERE id = #{id}
    </delete>

</mapper>
